# ─── Lovable Cloud (auto-provisioned, DO NOT edit) ────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_ENV=development
VITE_APP_BASE_URL=http://localhost:5173
VITE_DEMO_MODE=false

# ─── Analytics (PostHog / GA4) ────────────────────────────────────────────────
VITE_ANALYTICS_ENABLED=false
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# ─── Error Tracking (Sentry) ─────────────────────────────────────────────────
VITE_ERROR_TRACKING_ENABLED=false
VITE_SENTRY_DSN=

# ─── AI Features ─────────────────────────────────────────────────────────────
VITE_AI_ENABLED=true
# AI provider/model are locked server-side in supabase/functions/parse-cv-ai/index.ts
# Backend secret only: OPENAI_API_KEY
# Do not expose provider/model via VITE_ env vars

# ─── File Storage ─────────────────────────────────────────────────────────────
VITE_STORAGE_CV_BUCKET=cvs
VITE_STORAGE_MAX_UPLOAD_SIZE=10485760

# ─── Email (edge-function only, VITE_ vars just toggle UI) ───────────────────
VITE_EMAIL_ENABLED=false
VITE_EMAIL_FROM=noreply@findmygig.app
