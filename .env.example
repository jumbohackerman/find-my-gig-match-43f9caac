# =============================================================================
# JobSwipe.pl — Environment Variables
# MIGRATION GUIDE: To self-host, copy this file to .env and fill in all values.
# Frontend vars (VITE_*) are public. Backend secrets are set in Supabase
# (Lovable Cloud) via: supabase secrets set KEY=value
# =============================================================================

# ─── SUPABASE (auto-provisioned by Lovable Cloud, do NOT edit in .env) ───────
VITE_SUPABASE_URL=                     # Your Supabase project URL
VITE_SUPABASE_PUBLISHABLE_KEY=         # Public anon/publishable key (safe to expose)
VITE_SUPABASE_PROJECT_ID=              # Project ref id (e.g. abcd1234)

# ─── APP ─────────────────────────────────────────────────────────────────────
VITE_APP_ENV=development               # development | staging | production
VITE_APP_BASE_URL=http://localhost:5173
VITE_DEMO_MODE=false

# ─── CORS (used in edge functions) ───────────────────────────────────────────
# Your production frontend URL, used for CORS in edge functions.
# Set via: supabase secrets set ALLOWED_ORIGIN=https://jobswipe.pl
ALLOWED_ORIGIN=

# ─── AI (used in edge functions only — NEVER expose to frontend) ─────────────
# Provider-agnostic AI configuration. Backend secrets, set via:
#   supabase secrets set AI_API_KEY=...
#   supabase secrets set AI_MODEL=...
#   supabase secrets set AI_API_URL=...
AI_API_KEY=                            # Anthropic / OpenAI / OpenRouter key
AI_MODEL=                              # e.g. claude-opus-4-5, gpt-5, google/gemini-2.5-pro
AI_API_URL=                            # e.g. https://api.anthropic.com/v1/messages
# Legacy (still used by parse-cv-ai). Migration target: AI_API_KEY above.
OPENAI_API_KEY=

# Frontend toggle only (does not contain secrets):
VITE_AI_ENABLED=true

# ─── EMAIL (used in send-email edge function only) ───────────────────────────
# Set via: supabase secrets set RESEND_API_KEY=... RESEND_FROM_EMAIL=...
RESEND_API_KEY=                        # Get from https://resend.com
RESEND_FROM_EMAIL=                     # e.g. noreply@jobswipe.pl
VITE_EMAIL_ENABLED=false               # Frontend UI toggle only
VITE_EMAIL_FROM=noreply@jobswipe.pl    # Display only

# ─── ANALYTICS (PostHog, optional — silent no-op if unset) ───────────────────
VITE_ANALYTICS_ENABLED=false
VITE_POSTHOG_KEY=                      # Get from https://posthog.com
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# ─── ERROR TRACKING (Sentry, optional — silent no-op if unset) ───────────────
VITE_ERROR_TRACKING_ENABLED=false
VITE_SENTRY_DSN=                       # Get from https://sentry.io

# ─── FILE STORAGE ────────────────────────────────────────────────────────────
VITE_STORAGE_CV_BUCKET=cvs
VITE_STORAGE_MAX_UPLOAD_SIZE=10485760  # 10 MB in bytes
